# Java / Maven
target/
*.class
*.war

# Maven wrapper jar SHOULD be committed (it's how the wrapper bootstraps on a
# fresh checkout), so ignore other jars but keep it.
*.jar
!.mvn/wrapper/maven-wrapper.jar

# Node / frontend
node_modules/
dist/
build/
.vite/
*.tsbuildinfo

# Test / coverage output
coverage/
/backend/target/surefire-reports/

# Environment files - never commit secrets.
# .env.example is intentionally NOT ignored: it's a committed template.
.env
.env.local
.env.*.local
application-local.yml
application-secrets.yml

# IDE
.idea/
*.iml
.vscode/*
!.vscode/extensions.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Locally stored uploaded files (verification documents, etc.)
/backend/uploads/
/uploads/

# Misc Spring Boot helper file
HELP.md
